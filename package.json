{
  "name": "luke",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --filter @tuler/luke-webapp dev",
    "mock": "bun --filter @tuler/luke-mock start",
    "build": "bun --filter @tuler/luke-webapp build",
    "build:packages": "bun --filter @tuler/luke-decoder --filter @tuler/luke-json-decoder --filter @tuler/luke-perp-dex-decoder build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "registry:up": "docker compose -f infra/docker-compose.yml up -d --wait",
    "registry:down": "docker compose -f infra/docker-compose.yml down -v",
    "registry:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "publish:packages": "bun run build:packages && bun infra/publish.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
